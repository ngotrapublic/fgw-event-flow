# =========================================
# BACKEND ENVIRONMENT CONFIGURATION
# Environment: PRODUCTION
# ⚠️ DO NOT COMMIT THIS FILE TO VERSION CONTROL
# =========================================

NODE_ENV=production
PORT=5000
LOG_LEVEL=warn

# Firebase (Production Project)
FIREBASE_PROJECT_ID=your-production-project-id
FIREBASE_CLIENT_EMAIL=your-prod-service-account@your-production-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRODUCTION_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Email (Production)
EMAIL_USER=noreply@your-domain.com
EMAIL_PASS=your-production-app-password
EMAIL_FROM="Event Management System <noreply@your-domain.com>"

# API Settings
API_RATE_LIMIT=100
CORS_ORIGIN=https://your-domain.com

# Feature Flags
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_AUDIT_LOGGING=true
